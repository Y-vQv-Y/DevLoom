{
  "expo": {
    "name": "DevLoom",
    "slug": "devloom",
    "version": "260608",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "devloom",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "enabled": false,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "io.github.yvqvy.devloom",
      "buildNumber": "1",
      "icon": {
        "light": "./assets/icon.png",
        "dark": "./assets/icon-dark.png"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "用于语音输入，将你的语音实时转写为文字",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "package": "io.github.yvqvy.devloom",
      "versionCode": 1,
      "permissions": [
        "RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-router",
      "expo-font",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/splash-dark.png",
            "backgroundColor": "#0b0b0e"
          }
        }
      ],
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "photosPermission": "用于选择图片作为对话附件发送给 AI"
        }
      ],
      [
        "expo-media-library",
        {
          "savePhotosPermission": "用于把对话中的图片保存到相册",
          "photosPermission": false,
          "isAccessMediaLocationEnabled": false
        }
      ],
      "./plugins/withAndroidFileSaver",
      [
        "expo-build-properties",
        {
          "ios": {
            "buildReactNativeFromSource": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {}
  }
}
